# Copy to .env.local and fill in your key:
#   cp env.example .env.local
#
# Get an API key: https://console.agentmail.to
# Agent onboarding guide: https://www.agentmail.to/llms.txt

AGENTMAIL_API_KEY=am_your_key_here

# Role inboxes (must exist in your AgentMail account)
JILL_INBOX_EMAIL=jill-zenlabs@agentmail.to
HM_INBOX_EMAIL=hm-zenlabs@agentmail.to
ENG_INBOX_EMAIL=eng-zenlabs@agentmail.to

# Optional display names for intro / loop-in templates
# HM_DISPLAY_NAME=Hiring Manager
# ENG_DISPLAY_NAME=Engineering

# Optional — shown as the webhook URL hint in Settings
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Webhooks (configure in AgentMail dashboard, one per inbox):
#   {NEXT_PUBLIC_APP_URL}/api/agentmail/webhooks?role=jill
#   {NEXT_PUBLIC_APP_URL}/api/agentmail/webhooks?role=hm
#   {NEXT_PUBLIC_APP_URL}/api/agentmail/webhooks?role=eng
